# Test environment for API integration tests (committed: local dev placeholders, NOT real secrets).
# Loaded by tests/setup-test-env.ts before AppModule compiles. In CI the
# backend-integration job sets these via job-level env (which takes precedence).
DATABASE_URL="postgresql://postgres:1234@localhost:5432/real-estate-test-db?schema=public"

BCRYPT_SALT_ROUNDS=10
JWT_SECRET=test-jwt-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test-jwt-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
PORT=3001
FRONTEND_URL=http://localhost:3000
